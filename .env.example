# ── Flask ──────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production

# ── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sana_db

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600        # 1 hour in seconds
JWT_REFRESH_TOKEN_EXPIRES=2592000    # 30 days in seconds

# ── Admin ────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@sana.com

# ── Email ───────────────────────────────────────────────
# For Gmail, use an App Password (not your regular password)
# Generate one at: https://myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=iamyxn12@gmail.com
MAIL_PASSWORD=your-gmail-app-password-here
MAIL_DEFAULT_SENDER=iamyxn12@gmail.com

# ── File Upload ──────────────────────────────────────────
UPLOAD_FOLDER=app/uploads
MAX_CONTENT_LENGTH=5242880           # 5 MB
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,webp

# ── WhatsApp (Twilio or Meta Cloud API) ─────────────────
WHATSAPP_PHONE_NUMBER=917799296786
WHATSAPP_API_TOKEN=your-whatsapp-token
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token

# ── CORS ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
